# Generated by Cargo
# will have compiled files and executables
/target/

# ffmpeg externalBin(s) downloaded by the release CI (see release.yml). Never
# committed — they're large and fetched fresh at build time.
/binaries/

# Generated by Tauri
# will have schema files for capabilities auto-completion
/gen/schemas

# Updater signing keys — the private key is a top-tier secret (see release CI).
# Only the .pub is safe to commit; never commit the private key.
*.key
