{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Stingle Desktop",
  "version": "0.1.5",
  "identifier": "org.stingle.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Stingle Desktop",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 600,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob: asset: stingle: http://stingle.localhost https://stingle.localhost http://asset.localhost https://asset.localhost; media-src 'self' blob: stingle: http://stingle.localhost https://stingle.localhost http://127.0.0.1:*; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; base-uri 'self'; form-action 'self'; frame-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "macOS": {
      "entitlements": "entitlements.plist"
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      },
      "deb": {
        "depends": [
          "gstreamer1.0-plugins-good",
          "gstreamer1.0-plugins-bad",
          "gstreamer1.0-libav"
        ]
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/stingle/stingle-desktop/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ3QkIxNkJCRDZEMDE1QjcKUldTM0ZkRFd1eGE3MTJ0YnIvREUyWkFlUWNqVDdUSVdLQmp4UVAxZWxrNzB6Q0dITFlKRWQ1QTcK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
